# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/ss-dental-health

# Port for the API server
PORT=5000

# Allowed origin for CORS (your frontend URL)
CLIENT_URL=http://localhost:5173

# ---- CallMeBot WhatsApp notification settings ----
# 1. Save this number in your phone contacts: +34 644 59 71 44 (CallMeBot's official number)
# 2. Send this exact message on WhatsApp to that number: "I allow callmebot to send me messages"
# 3. You will receive an API key back on WhatsApp within a minute or two.
# 4. Fill in YOUR whatsapp number (with country code, no + or spaces) and the API key below.
OWNER_WHATSAPP_NUMBER=91XXXXXXXXXX
CALLMEBOT_API_KEY=your_callmebot_api_key_here

# Simple key to protect the admin "view all appointments" endpoint
ADMIN_KEY=change_this_to_something_secret
